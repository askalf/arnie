{
  "name": "arnie-cli",
  "version": "1.1.1",
  "description": "Portable IT troubleshooting companion powered by Claude",
  "type": "module",
  "bin": {
    "arnie": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/test-tools.ts",
    "test:integration": "bash test/integration.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "chalk": "^5.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
